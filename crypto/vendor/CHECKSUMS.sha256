# SHA-256 checksums of vendored cryptographic dependencies.
# These MUST match the official npm release artifacts.
#
# To verify:
#   shasum -a 256 crypto/vendor/tweetnacl.cjs crypto/vendor/tweetnacl-util.cjs
#
# To compare against npm originals:
#   npm pack tweetnacl@1.0.3 && tar xf tweetnacl-1.0.3.tgz
#   shasum -a 256 package/nacl-fast.js
#   npm pack tweetnacl-util@0.15.1 && tar xf tweetnacl-util-0.15.1.tgz
#   shasum -a 256 package/nacl-util.js


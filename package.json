{
  "name": "p2chat",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node server/index.js",
    "test": "node crypto/selftest.js && node audit/check-crypto-isolation.js && bash audit/check-deps.sh",
    "test:crypto": "node crypto/selftest.js",
    "test:audit": "node audit/check-crypto-isolation.js && bash audit/check-deps.sh",
    "test:build": "bash audit/check-build.sh"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^1.6.0",
    "prebuilt-tdlib": "^0.1008062.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tdl": "^8.1.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^6.2.4"
  }
}
